# --- Required (every phase) ---

# OpenAI API key for the bot reply + nightly batch + LangGraph Cypher generation.
OPENAI_API_KEY=sk-...

# --- Phase 0: deployment plumbing ---

# Comma-separated list of allowed CORS origins for the frontend.
# Local dev: http://localhost:5173
# Production: https://<your-vercel-url>
CORS_ORIGINS=http://localhost:5173

# --- Phase 1: Postgres (replaces journal.db) ---

# Connection string for the Postgres database. For local dev with the Supabase
# CLI: postgresql://postgres:postgres@127.0.0.1:54322/postgres
# For production: the "Session pooler" string from Supabase dashboard.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Phase 2: multi-tenant dev shim ---

# UUID of the local-dev user. While auth is not wired up yet, every request
# is treated as coming from this user. Must match a row in auth.users.
# Unset (or removed) once Phase 3 is live in this environment.
DEV_USER_ID=

# --- Phase 3: Supabase auth ---

# Supabase project URL and the symmetric JWT secret used to verify access
# tokens. Both come from the Supabase dashboard (Settings → API).
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_JWT_SECRET=

# --- Phase 4: deployment ---

# Shared secret for the GitHub Actions nightly-batch webhook
# (POST /api/admin/run-batch). Generate with: openssl rand -hex 32
# When empty, the webhook refuses to fire (returns 503) — safe local default.
BATCH_WEBHOOK_SECRET=

# When true, the in-process APScheduler cron runs on app startup. Leave true
# for local development (so the 06:00 batch fires without external triggers),
# set false on Render where GitHub Actions invokes the batch webhook instead.
RUN_INLINE_SCHEDULER=true

# --- Neo4j (already used today) ---

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mindforge

# --- Optional / behavior knobs ---

# Hour of the day (local time) that defines the 6 AM day boundary.
DAY_BOUNDARY_HOUR=6

# Cap on the number of active goals per user.
MAX_ACTIVE_GOALS=3

# PostHog product analytics (optional — server is a no-op if unset)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

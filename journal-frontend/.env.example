# Base URL of the FastAPI backend.
# Local dev: http://127.0.0.1:8000
# Production: https://<your-render-service>.onrender.com
VITE_API_URL=http://127.0.0.1:8000

# Supabase project URL and anon (public) key. Both come from the Supabase
# dashboard (Settings → API). The anon key is safe to ship to the browser.
# Required from Phase 3 onward; unset for Phase 0/1/2 local dev.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

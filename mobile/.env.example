# Copy to mobile/.env and fill in. EXPO_PUBLIC_* vars are inlined at build time.
# The anon key is a publishable key (safe in the client), same value as the web app.
EXPO_PUBLIC_SUPABASE_URL=https://iazqotzjesomoyqfelgt.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Defaults to prod Render if unset; override for local backend testing.
EXPO_PUBLIC_API_URL=https://ai-journalling-app-api.onrender.com

# RevenueCat (paywall). UNSET = paywall off (nobody is gated). Set the iOS
# public SDK key + create the "premium" entitlement/products to flip on the
# hard paywall. See components/Paywall.tsx + lib/purchases.ts.
EXPO_PUBLIC_REVENUECAT_API_KEY=

# PostHog client analytics (onboarding funnel). UNSET = analytics off (no-op).
# Reuse the same phc_ project key as the backend. APP_ENV tags events so staging
# can be filtered out (mirrors the server's APP_ENV).
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_APP_ENV=production

# --- Staging (point the local dev client at the staging stack) ---
# To run `expo start` against staging, copy these three over the values above.
# (EAS builds get them automatically via the `staging` profile in eas.json.)
#   EXPO_PUBLIC_API_URL=https://ai-journalling-app-api-staging.onrender.com
#   EXPO_PUBLIC_SUPABASE_URL=https://eqwijryhjubgnyetufpa.supabase.co
#   EXPO_PUBLIC_SUPABASE_ANON_KEY=<staging anon key — see docs/staging.md>
